@page
@model LootTablesModel
@{
    ViewData["Title"] = "Loot Tables";
}

<link rel="stylesheet" href="~/css/items.css" />
<link rel="stylesheet" href="~/css/loottables.css" />

<div class="items-page">
    <div class="items-header">
        <h1>🎲 Loot Tables</h1>
        <div class="d-flex gap-2 align-items-center">
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAllFoldouts()">⊟ Colapsar todo</button>
            <button type="button" class="btn btn-success px-4" onclick="saveAllLt()">💾 Guardar todo</button>
            <button type="button" class="btn btn-primary px-4" onclick="document.getElementById('addTableModal').style.display='flex'">+ Nueva Loot Table</button>
        </div>
    </div>
    <div class="filter-bar">
        <input type="text" id="ltSearch" class="form-control" placeholder="Buscar por nombre... (Enter)" value="@Model.SearchQuery" onkeydown="if(event.key==='Enter'){var q=this.value.trim();window.location.href=q?'/LootTables?search='+encodeURIComponent(q):'/LootTables'}" />
    </div>

    <!-- Modal Nueva Loot Table -->
    <div id="addTableModal" class="modal-overlay">
        <div class="modal-card">
            <h4>🎲 Nueva Loot Table</h4>
            <form method="post" asp-page-handler="AddTable">
                <div class="mb-3">
                    <label>Nombre</label>
                    <input class="form-control" name="NewTableName" placeholder="Nombre de la loot table..." required />
                </div>
                <div class="modal-footer-btns">
                    <button type="submit" class="btn btn-success">Crear</button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('addTableModal').style.display='none'">Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Add Entry -->
    <div id="addEntryModal" class="modal-overlay">
        <div class="modal-card">
            <h4>➕ Añadir Entrada</h4>
            <form method="post" asp-page-handler="AddEntry">
                <input type="hidden" id="addEntryTableId" name="NewEntry.LootTableId" />
                <div class="mb-3">
                    <label>Item</label>
                    <select class="form-select" name="NewEntry.ItemId" required>
                        <option value="">-</option>
                        @foreach (var item in Model.AllItems)
                        {
                            <option value="@item.Id">@(item.Name ?? item.Id)</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label>Probability (%)</label>
                    <input class="form-control" type="number" name="NewEntry.Probability" min="0" max="100" />
                </div>
                <div class="mb-3">
                    <label>Min Amount</label>
                    <input class="form-control" type="number" name="NewEntry.MinAmount" min="1" />
                </div>
                <div class="mb-3">
                    <label>Max Amount</label>
                    <input class="form-control" type="number" name="NewEntry.MaxAmount" min="1" />
                </div>
                <div class="modal-footer-btns">
                    <button type="submit" class="btn btn-success">Guardar</button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('addEntryModal').style.display='none'">Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="lt-list" id="ltList">
        @foreach (var table in Model.LootTables)
        {
            <details class="lt-entry" data-name="@((table.LootTableName ?? "").ToLower())" open>
                <summary class="lt-header">
                    <span class="lt-id">@(table.LootTableName ?? $"Loot Table #{table.Id}")</span>
                    <div class="d-flex gap-2" onclick="event.stopPropagation()">
                        <button type="button" class="btn btn-outline-success btn-sm" onclick="openAddEntry(@table.Id)">+ Entrada</button>
                        <form method="post" asp-page-handler="DeleteTable" style="margin:0">
                            <input type="hidden" name="id" value="@table.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Eliminar</button>
                        </form>
                    </div>
                </summary>
                <div class="lt-entries">
                    @if (!table.Entries.Any())
                    {
                        <span class="lt-empty">Sin entradas</span>
                    }
                    else
                    {
                        <div class="lt-entries-header">
                            <span>Item</span>
                            <span>Probability</span>
                            <span>Min</span>
                            <span>Max</span>
                            <span></span>
                        </div>
                        <form method="post" asp-page-handler="SaveEntries" id="form-lt-@table.Id">
                        <input type="hidden" name="SaveEntriesTableId" value="@table.LootTableId" />
                        @{ int ei = 0; }
                        @foreach (var entry in table.Entries)
                        {
                            <input type="hidden" name="Entries[@ei].Id" value="@entry.Id" />
                            <div class="lt-entry-row">
                                <span class="lt-item-name">
                                    @if (entry.Item?.Icon != null)
                                    {
                                        <img src="data:image/png;base64,@UnityDataImporter.Utils.ImageUtils.ToBase64(entry.Item.Icon)" class="lt-item-icon" />
                                    }
                                    @(entry.Item?.Name ?? entry.ItemId)
                                </span>
                                <input type="text" inputmode="numeric" class="form-control form-control-sm" name="Entries[@ei].Probability" value="@entry.Probability" />
                                <input type="text" inputmode="numeric" class="form-control form-control-sm" name="Entries[@ei].MinAmount" value="@entry.MinAmount" />
                                <input type="text" inputmode="numeric" class="form-control form-control-sm" name="Entries[@ei].MaxAmount" value="@entry.MaxAmount" />
                                <div class="lt-row-actions">
                                    <button type="submit" form="del-entry-@entry.Id" class="btn btn-outline-danger btn-sm py-0 px-1">✕</button>
                                </div>
                            </div>
                            ei++;
                        }
                        </form>
                        @foreach (var entry in table.Entries)
                        {
                            <form method="post" asp-page-handler="DeleteEntry" id="del-entry-@entry.Id" style="display:none">
                                <input type="hidden" name="id" value="@entry.Id" />
                                <input type="hidden" name="lootTableId" value="@table.LootTableId" />
                            </form>
                        }
                        <div style="display:none">
                            <button type="submit" form="form-lt-@table.Id" class="btn btn-success btn-sm">💾 Guardar</button>
                        </div>
                    }
                </div>
            </details>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav style="display:flex;justify-content:center;align-items:center;gap:0.5rem;margin-top:1.5rem">
            @if (Model.CurrentPage > 1)
            {
                <a class="btn btn-outline-secondary btn-sm" href="/LootTables?p=@(Model.CurrentPage - 1)&search=@Model.SearchQuery">← Anterior</a>
            }
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                if (p == Model.CurrentPage)
                {
                    <span class="btn btn-primary btn-sm" style="pointer-events:none">@p</span>
                }
                else
                {
                    <a class="btn btn-outline-secondary btn-sm" href="/LootTables?p=@p&search=@Model.SearchQuery">@p</a>
                }
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a class="btn btn-outline-secondary btn-sm" href="/LootTables?p=@(Model.CurrentPage + 1)&search=@Model.SearchQuery">Siguiente →</a>
            }
        </nav>
    }
</div>

<script>
    const dirtyLtForms = new Set();

    function saveAllLt() {
        if (dirtyLtForms.size === 0) { alert('No hay cambios para guardar'); return; }
        const firstId = dirtyLtForms.values().next().value;
        document.getElementById('form-lt-' + firstId).submit();
    }

    function toggleAllFoldouts() {
        const btn = document.querySelector('[onclick="toggleAllFoldouts()"]');
        const entries = document.querySelectorAll('#ltList .lt-entry');
        const anyOpen = [...entries].some(el => el.open);
        entries.forEach(el => el.open = !anyOpen);
        btn.textContent = anyOpen ? '⊞ Expandir todo' : '⊟ Colapsar todo';
    }

    function openAddEntry(tableId) {
        document.getElementById('addEntryTableId').value = tableId;
        document.getElementById('addEntryModal').style.display = 'flex';
    }

    

    document.querySelectorAll('[id^="form-lt-"] input').forEach(el => {
        el.addEventListener('input', () => {
            const form = el.closest('form');
            const tableId = form.id.replace('form-lt-', '');
            dirtyLtForms.add(tableId);
        }, { once: true });
    });
</script>
