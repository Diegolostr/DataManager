@page
@model ItemsModel
@{
    ViewData["Title"] = "Items";
}

<link rel="stylesheet" href="~/css/items.css" />

<div class="items-page">
    <div class="items-header">
        <h1>🗡️ Items</h1>
        <div class="d-flex align-items-center gap-3">
            @if (Model.FilteredItemId != null)
            {
                <span class="badge bg-primary fs-6">🔍 @Model.FilteredItemId</span>
                <a class="btn btn-outline-secondary btn-sm" asp-page="Items">Ver todos</a>
            }
            <button class="btn btn-primary px-4" onclick="document.getElementById('addModal').style.display='flex'">
                + Nuevo Item
            </button>
        </div>
    </div>

    <!-- Modal Nuevo -->
    <div id="addModal" class="modal-overlay">
        <div class="modal-card modal-card-lg">
            <h4>➕ Nuevo Item</h4>
            <form method="post" asp-page-handler="AddItem" enctype="multipart/form-data">
                <div class="modal-form-grid">
                    <div class="mb-3">
                        <label>Id</label>
                        <input class="form-control" asp-for="NewItem.Id" required />
                    </div>
                    <div class="mb-3">
                        <label>Name</label>
                        <input class="form-control" asp-for="NewItem.Name" />
                    </div>
                    <div class="mb-3">
                        <label>Description</label>
                        <input class="form-control" asp-for="NewItem.Description" required />
                    </div>
                    <div class="mb-3">
                        <label>Type</label>
                        <div class="input-group">
                            <select class="form-select" asp-for="NewItem.ItemType" id="newItemType" onchange="onNewItemTypeChange(this)">
                                <option value="">-</option>
                                @foreach (var t in Model.ItemTypes) { <option value="@t">@t</option> }
                            </select>
                            <button type="button" class="btn btn-outline-secondary" onclick="toggleInline('addItemTypeForm', this)">+</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Rarity</label>
                        <div class="input-group">
                            <select class="form-select" asp-for="NewItem.ItemRarity">
                                <option value="">-</option>
                                @foreach (var r in Model.Rarities) { <option value="@r">@r</option> }
                            </select>
                            <button type="button" class="btn btn-outline-secondary" onclick="toggleInline('addRarityForm', this)">+</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Inventory Sound</label>
                        <select class="form-select" asp-for="NewItem.ItemSoundType">
                            <option value="">-</option>
                            @foreach (var s in Model.InventorySounds) { <option value="@s.Id">@s.Sound</option> }
                        </select>
                    </div>
                    <div class="mb-3" id="new-field-equipslot" style="display:none">
                        <label>Equipment Slot</label>
                        <select class="form-select" asp-for="NewItem.EquipmentSlot">
                            <option value="">-</option>
                            @foreach (var s in Model.EquipmentSlots) { <option value="@s">@s</option> }
                        </select>
                    </div>
                    <div class="mb-3" id="new-field-holdtype" style="display:none">
                        <label>Hold Type</label>
                        <div class="input-group">
                            <select class="form-select" asp-for="NewItem.HoldType">
                                <option value="">-</option>
                                @foreach (var h in Model.HoldTypes) { <option value="@h">@h</option> }
                            </select>
                            <button type="button" class="btn btn-outline-secondary" onclick="toggleInline('addHoldTypeForm', this)">+</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Stackable</label>
                        <select class="form-select" asp-for="NewItem.IsStackable" onchange="onStackableChange(this)">
                            <option value="">-</option>
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label>Max Amount</label>
                        <input class="form-control" type="number" asp-for="NewItem.MaxAmount" id="maxAmount" />
                    </div>
                    <div class="mb-3">
                        <label>Buy Amount</label>
                        <input class="form-control" type="number" asp-for="NewItem.BuyAmount" />
                    </div>
                    <div class="mb-3">
                        <label>Sell Amount</label>
                        <input class="form-control" type="number" asp-for="NewItem.SellAmount" />
                    </div>
                    <div class="mb-3">
                        <label>Can Block</label>
                        <select class="form-select" asp-for="NewItem.CanBlock" onchange="onNewCanBlockChange(this)">
                            <option value="">-</option>
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>
                    <div class="mb-3" id="new-field-blockamount" style="display:none">
                        <label>Block Amount</label>
                        <input class="form-control" type="number" step="0.01" asp-for="NewItem.BlockAmount" />
                    </div>
                    <div class="mb-3" id="new-field-blocksound" style="display:none">
                        <label>Block Sound</label>
                        <input class="form-control" type="file" name="NewBlockSound" accept="audio/*" />
                    </div>
                    <div class="mb-3" id="new-field-parryaudio" style="display:none">
                        <label>Parry Audio</label>
                        <input class="form-control" type="file" name="NewParryAudio" accept="audio/*" />
                    </div>
                </div>
                <div class="modal-footer-btns">
                    <button type="submit" class="btn btn-success">Guardar</button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('addModal').style.display='none'">Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Add Item Event (JS only, no server submit) -->
    <div id="addItemEventModal" class="modal-overlay">
        <div class="modal-card">
            <h4>🎯 Añadir Event</h4>
            <div class="mb-3">
                <label>Event Type</label>
                <select class="form-select" id="pendingEventTypeSelect">
                    <option value="">-</option>
                    @foreach (var et in Model.EventTypes)
                    {
                        <option value="@et.Id" data-name="@(et.EventName ?? "")" data-icon="@(et.Icon != null ? UnityDataImporter.Utils.ImageUtils.ToBase64(et.Icon) : "")">
                            @et.Id@(et.EventName != null ? $" — {et.EventName}" : "")
                        </option>
                    }
                </select>
            </div>
            <div class="modal-footer-btns">
                <button type="button" class="btn btn-success" onclick="confirmAddEvent()">Añadir</button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('addItemEventModal').style.display='none'">Cancelar</button>
            </div>
        </div>
    </div>

    <!-- Modal Add Stat (JS only) -->
    <div id="addStatModal" class="modal-overlay">
        <div class="modal-card">
            <h4>📊 Añadir Stat</h4>
            <div class="mb-3">
                <label>Stat</label>
                <select class="form-select" id="pendingStatSelect">
                    <option value="">-</option>
                    @foreach (var s in Model.StatTypes) { <option value="@s">@s</option> }
                </select>
            </div>
            <div class="mb-3">
                <label>Amount</label>
                <input class="form-control" type="number" id="pendingStatAmount" />
            </div>
            <div class="modal-footer-btns">
                <button type="button" class="btn btn-success" onclick="confirmAddStat()">Añadir</button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('addStatModal').style.display='none'">Cancelar</button>
            </div>
        </div>
    </div>

    <!-- Modal Weapon (JS only) -->
    <!-- removed: weapon fields are now inline in the card -->

    <!-- Modal Add Magic Attack (JS only) -->
    <div id="addMagicModal" class="modal-overlay">
        <div class="modal-card">
            <h4>✨ Magic Attack</h4>
            <input type="hidden" id="magicModalItemId" />
            <input type="hidden" id="magicModalEditId" value="0" />
            <div class="mb-3"><label>Magic Type</label>
                <select class="form-select" id="mMagicType">
                    <option value="">-</option>
                    @foreach (var mt in Model.MagicTypes) { <option value="@mt">@mt</option> }
                </select>
            </div>
            <div class="mb-3"><label>Magic Damage</label><input class="form-control" type="number" id="mDamage" /></div>
            <div class="mb-3"><label>Cooldown</label><input class="form-control" type="number" step="0.01" id="mCooldown" /></div>
            <div class="mb-3"><label>Projectile Speed</label><input class="form-control" type="number" step="0.01" id="mProjSpeed" /></div>
            <div class="mb-3"><label>Effect Type</label>
                <select class="form-select" id="mEffectType">
                    <option value="">-</option>
                    @foreach (var et in Model.EffectTypes) { <option value="@et">@et</option> }
                </select>
            </div>
            <div class="mb-3"><label>Mana Consumption</label><input class="form-control" type="number" id="mMana" /></div>
            <div class="mb-3"><label>Max Companions</label><input class="form-control" type="number" id="mCompanions" /></div>
            <div class="modal-footer-btns">
                <button type="button" class="btn btn-success" onclick="confirmMagic()">Añadir</button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('addMagicModal').style.display='none'">Cancelar</button>
            </div>
        </div>
    </div>

    <div class="filter-bar">
        <input type="text" id="itemSearch" class="form-control" placeholder="Buscar por ID, nombre o descripción..." oninput="applyFilters()" />
        <button class="btn btn-outline-secondary btn-sm" onclick="toggleFilters()">⚙️ Filtros</button>
        <button class="btn btn-outline-danger btn-sm" onclick="clearFilters()">✕ Limpiar</button>
    </div>
    <div class="filter-panel" id="filterPanel" style="display:none">
        <div class="filter-grid">
            <div>
                <label class="filter-label">Item Type</label>
                <select id="f-type" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">Todos</option>
                    @foreach (var t in Model.ItemTypes) { <option value="@t.ToLower()">@t</option> }
                </select>
            </div>
            <div>
                <label class="filter-label">Rarity</label>
                <select id="f-rarity" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">Todas</option>
                    @foreach (var r in Model.Rarities) { <option value="@r.ToLower()">@r</option> }
                </select>
            </div>
            <div>
                <label class="filter-label">Equipment Slot</label>
                <select id="f-slot" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">Todos</option>
                    @foreach (var s in Model.EquipmentSlots) { <option value="@s.ToLower()">@s</option> }
                </select>
            </div>
            <div>
                <label class="filter-label">Hold Type</label>
                <select id="f-hold" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">Todos</option>
                    @foreach (var h in Model.HoldTypes) { <option value="@h.ToLower()">@h</option> }
                </select>
            </div>
            <div>
                <label class="filter-label">Stackable</label>
                <select id="f-stack" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">Todos</option>
                    <option value="true">Sí</option>
                    <option value="false">No</option>
                </select>
            </div>
            <div>
                <label class="filter-label">Can Block</label>
                <select id="f-block" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">Todos</option>
                    <option value="true">Sí</option>
                    <option value="false">No</option>
                </select>
            </div>
            <div>
                <label class="filter-label">Weapon Data</label>
                <select id="f-weapon" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">Todos</option>
                    <option value="yes">Tiene</option>
                    <option value="no">No tiene</option>
                </select>
            </div>
        </div>
    </div>

    <div class="items-list @(Model.FilteredItemId != null ? "item-detail-mode" : "")" id="itemsList">
        @foreach (var item in Model.Items)
        {
            <div class="item-entry"
                 data-id="@item.Id.ToLower()"
                 data-name="@(item.Name?.ToLower() ?? "")"
                 data-desc="@(item.Description?.ToLower() ?? "")"
                 data-type="@(item.ItemType?.ToLower() ?? "")"
                 data-rarity="@(item.ItemRarity?.ToLower() ?? "")"
                 data-slot="@(item.EquipmentSlot?.ToLower() ?? "")"
                 data-hold="@(item.HoldType?.ToLower() ?? "")"
                 data-stack="@(item.IsStackable?.ToString().ToLower() ?? "")"
                 data-block="@(item.CanBlock?.ToString().ToLower() ?? "")"
                 data-weapon="@(item.Weapon != null ? "yes" : "no")">
                <!-- Header -->
                <div class="item-entry-header">
                    <div class="item-row-icon">
                        @if (item.Icon != null)
                        {
                            <img src="data:image/png;base64,@UnityDataImporter.Utils.ImageUtils.ToBase64(item.Icon)" />
                        }
                        else
                        {
                            <span class="no-icon">?</span>
                        }
                        <a class="item-row-id" href="/Items?itemId=@item.Id">@(item.Name ?? item.Id)</a>
                    </div>
                    <button type="button" class="btn btn-outline-warning btn-sm" onclick="enableEdit('@item.Id')">✏️ Editar</button>
                    <button type="button" class="btn btn-success btn-sm" id="btn-save-@item.Id" style="display:none" onclick="document.getElementById('form-@item.Id').submit()">💾 Guardar</button>
                    <button type="button" class="btn btn-secondary btn-sm" id="btn-cancel-@item.Id" style="display:none" onclick="cancelEdit('@item.Id')">✕ Cancelar</button>
                    <form method="post" asp-page-handler="DeleteItem" style="margin:0" onsubmit="return confirm('¿Eliminar @item.Id?')">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
                    </form>
                </div>

                <!-- cards -->
                <form id="form-@item.Id" method="post" asp-page-handler="SaveItem" enctype="multipart/form-data">
                <input type="hidden" name="EditItemId" value="@item.Id" />
                <input type="hidden" name="FilteredItemId" value="@Model.FilteredItemId" />
                <input type="hidden" name="PendingStatsJson" id="pendingStats-@item.Id" value="[]" />
                <input type="hidden" name="DeletedStatsJson" id="deletedStats-@item.Id" value="[]" />
                <input type="hidden" name="PendingEventsJson" id="pendingEvents-@item.Id" value="[]" />
                <input type="hidden" name="DeletedEventsJson" id="deletedEvents-@item.Id" value="[]" />
                <input type="hidden" name="PendingWeaponJson" id="pendingWeapon-@item.Id" value="" />
                <input type="hidden" name="PendingMagicJson" id="pendingMagic-@item.Id" value="[]" />
                <input type="hidden" name="DeletedMagicJson" id="deletedMagic-@item.Id" value="[]" />
                <div class="item-cards-row">

                    <div class="icard">
                        <div class="icard-header">📋 Item Basic Data</div>
                        <div class="icard-body">
                            <div class="ifield"><span class="ilabel">Item Name</span><span class="ivalue"><input class="form-control form-control-sm" name="EditItem.Name" value="@item.Name" disabled /></span></div>
                            <div class="ifield"><span class="ilabel">Description</span><span class="ivalue"><input class="form-control form-control-sm" name="EditItem.Description" value="@item.Description" disabled /></span></div>
                            <div class="ifield"><span class="ilabel">Item ID</span><span class="ivalue"><code>@item.Id</code></span></div>
                            <div class="ifield">
                                <span class="ilabel">Item Size</span>
                                <span class="ivalue">@(item.Size != null ? $"X {item.Size.X}  Y {item.Size.Y}" : "-")</span>
                            </div>
                            <div class="ifield">
                                <span class="ilabel">Is Stackable</span>
                                <span class="ivalue">
                                    <select class="form-select form-select-sm" name="EditItem.IsStackable" onchange="onInlineStackableChange(this, '@item.Id')" disabled>
                                        <option value="">-</option>
                                        <option value="true" selected="@(item.IsStackable == true ? "selected" : null)">Sí</option>
                                        <option value="false" selected="@(item.IsStackable == false ? "selected" : null)">No</option>
                                    </select>
                                </span>
                            </div>
                            <div class="ifield"><span class="ilabel">Max Stack</span><span class="ivalue"><input class="form-control form-control-sm" type="number" name="EditItem.MaxAmount" id="inlineMaxAmount-@item.Id" value="@item.MaxAmount" disabled @(item.IsStackable == false ? "readonly" : "") /></span></div>
                            <div class="ifield">
                                <span class="ilabel">Icon</span>
                                <span class="ivalue" style="display:flex;align-items:center;gap:0.5rem">
                                    @if (item.Icon != null)
                                    {
                                        <img src="data:image/png;base64,@UnityDataImporter.Utils.ImageUtils.ToBase64(item.Icon)" style="width:32px;height:32px;object-fit:contain;image-rendering:pixelated;border:1px solid var(--border-subtle);border-radius:var(--radius-sm);padding:2px" />
                                    }
                                    else
                                    {
                                        <span style="width:32px;height:32px;background:var(--border-subtle);border-radius:var(--radius-sm);display:inline-flex;align-items:center;justify-content:center;font-size:0.9rem;color:var(--text-faint)">?</span>
                                    }
                                    <input type="file" id="icon-input-@item.Id" name="EditIcon" accept=".png,.jpg,.jpeg" style="display:none" />
                                    <button type="button" class="btn btn-ghost btn-xs icon-upload-btn" id="icon-btn-@item.Id" style="display:none" onclick="document.getElementById('icon-input-@item.Id').click()">Cambiar</button>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="icard">
                        <div class="icard-header">🗂️ Item Enums</div>
                        <div class="icard-body">
                            <div class="ifield"><span class="ilabel">Item Type</span><span class="ivalue">
                                <select class="form-select form-select-sm" name="EditItem.ItemType" onchange="onItemTypeChange(this, '@item.Id')" disabled>
                                    <option value="">-</option>
                                    @foreach (var t in Model.ItemTypes) { <option value="@t" selected="@(item.ItemType == t ? "selected" : null)">@t</option> }
                                </select>
                            </span></div>
                            <div class="ifield"><span class="ilabel">Item Rarity</span><span class="ivalue">
                                <select class="form-select form-select-sm" name="EditItem.ItemRarity" disabled>
                                    <option value="">-</option>
                                    @foreach (var r in Model.Rarities) { <option value="@r" selected="@(item.ItemRarity == r ? "selected" : null)">@r</option> }
                                </select>
                            </span></div>
                            <div class="ifield"><span class="ilabel">Item Sound</span><span class="ivalue">
                                <select class="form-select form-select-sm" name="EditItem.ItemSoundType" disabled>
                                    <option value="">-</option>
                                    @foreach (var s in Model.InventorySounds) { <option value="@s.Id" selected="@(item.ItemSoundType == s.Id ? "selected" : null)">@s.Sound</option> }
                                </select>
                            </span></div>
                            <div class="ifield" id="field-holdtype-@item.Id" style="display:@(new[]{ "sword","bow","book","shield" }.Contains(item.ItemType?.ToLower() ?? "") ? "" : "none")"><span class="ilabel">Hold Type</span><span class="ivalue">
                                <select class="form-select form-select-sm" name="EditItem.HoldType" disabled>
                                    <option value="">-</option>
                                    @foreach (var h in Model.HoldTypes) { <option value="@h" selected="@(item.HoldType == h ? "selected" : null)">@h</option> }
                                </select>
                            </span></div>
                            <div class="ifield" id="field-equipslot-@item.Id" style="display:@(new[]{ "sword","bow","book","armor","shield","weapon","accesory" }.Contains(item.ItemType?.ToLower() ?? "") ? "" : "none")"><span class="ilabel">Equipment Slot</span><span class="ivalue">
                                <select class="form-select form-select-sm" name="EditItem.EquipmentSlot" disabled>
                                    <option value="">-</option>
                                    @foreach (var s in Model.EquipmentSlots) { <option value="@s" selected="@(item.EquipmentSlot == s ? "selected" : null)">@s</option> }
                                </select>
                            </span></div>
                        </div>
                    </div>

                    <div class="icard">
                        <div class="icard-header">🛒 Shop</div>
                        <div class="icard-body">
                            <div class="ifield"><span class="ilabel">Buy Cost</span><span class="ivalue"><input class="form-control form-control-sm" type="number" name="EditItem.BuyAmount" value="@item.BuyAmount" disabled /></span></div>
                            <div class="ifield"><span class="ilabel">Sell Cost</span><span class="ivalue"><input class="form-control form-control-sm" type="number" name="EditItem.SellAmount" value="@item.SellAmount" disabled /></span></div>
                        </div>
                    </div>

                    <div class="icard">
                        <div class="icard-header">📊 Stats & Events</div>
                        <div class="icard-body">
                            <div id="stats-list-@item.Id">
                            @foreach (var sa in Model.StatsByItem[item.Id])
                            {
                                <div class="ifield" data-stat-id="@sa.Id">
                                    <span class="ilabel">@(sa.StatNavigation?.Id ?? sa.Stat)</span>
                                    <span class="ivalue d-flex align-items-center gap-2">
                                        @(sa.Amount?.ToString() ?? "-")
                                        <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1 edit-only" onclick="deleteStat('@item.Id', @sa.Id, this.closest('.ifield'))">✕</button>
                                    </span>
                                </div>
                            }
                            </div>
                            <div class="ifield edit-only" style="padding-top:0.5rem;border-top:1px solid var(--border-subtle)">
                                <span class="ilabel" style="color:var(--text-muted)">+ Stat</span>
                                <span class="ivalue"><button type="button" class="btn btn-outline-secondary btn-sm" onclick="openAddStat('@item.Id')">+</button></span>
                            </div>
                            <div style="border-top:1px solid var(--border-subtle);margin-top:0.5rem;padding-top:0.5rem">
                                <div id="events-list-@item.Id">
                                @foreach (var ie in Model.ItemEventsByItem[item.Id])
                                {
                                    <div class="ifield" data-event-id="@ie.Id">
                                        <span class="ilabel">Event</span>
                                        <span class="ivalue d-flex align-items-center gap-2">
                                            @if (ie.EventType?.Icon != null)
                                            {
                                                <img src="data:image/png;base64,@UnityDataImporter.Utils.ImageUtils.ToBase64(ie.EventType.Icon)" style="width:20px;height:20px;object-fit:contain;image-rendering:pixelated" />
                                            }
                                            <span class="badge bg-secondary">@(ie.EventType?.Id ?? ie.EventTypeId ?? "#" + ie.Id)</span>
                                            <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1 edit-only" onclick="deleteEvent('@item.Id', @ie.Id, this.closest('.ifield'))">✕</button>
                                        </span>
                                    </div>
                                }
                                </div>
                                <div class="ifield edit-only" style="padding-top:0.5rem">
                                    <span class="ilabel" style="color:var(--text-muted)">+ Event</span>
                                    <span class="ivalue"><button type="button" class="btn btn-outline-secondary btn-sm" onclick="openAddEvent('@item.Id')">+</button></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="icard" id="card-weapon-@item.Id" style="display:@(new[]{ "sword","bow","weapon" }.Contains(item.ItemType?.ToLower() ?? "") ? "" : "none")">
                        <div class="icard-header">⚔️ Weapon Info</div>
                        <div class="icard-body">
                            <div class="ifield"><span class="ilabel">Damage</span><span class="ivalue"><input class="form-control form-control-sm" type="number" id="wInline-damage-@item.Id" value="@item.Weapon?.Damage" oninput="syncWeapon('@item.Id')" disabled /></span></div>
                            <div class="ifield"><span class="ilabel">Heaviness</span><span class="ivalue"><input class="form-control form-control-sm" type="number" min="1" max="5" id="wInline-heaviness-@item.Id" value="@item.Weapon?.Heaviness" oninput="syncWeapon('@item.Id')" disabled /></span></div>
                            <div class="ifield"><span class="ilabel">Cooldown</span><span class="ivalue"><input class="form-control form-control-sm" type="number" step="0.01" id="wInline-cooldown-@item.Id" value="@item.Weapon?.Cooldown?.ToString(System.Globalization.CultureInfo.InvariantCulture)" oninput="syncWeapon('@item.Id')" disabled /></span></div>
                            <div class="ifield"><span class="ilabel">Ammo</span><span class="ivalue"><input class="form-control form-control-sm" id="wInline-ammo-@item.Id" value="@item.Weapon?.Ammo" list="ammoItemList" autocomplete="off" oninput="syncWeapon('@item.Id')" disabled /></span></div>
                        </div>
                    </div>

                    <div class="icard" id="card-block-@item.Id" style="display:@(new[]{ "sword","shield" }.Contains(item.ItemType?.ToLower() ?? "") ? "" : "none")">
                        <div class="icard-header">🛡️ Block Settings</div>
                        <div class="icard-body">
                            <div class="ifield"><span class="ilabel">Can Block</span><span class="ivalue">
                                <select class="form-select form-select-sm" name="EditItem.CanBlock" onchange="onCanBlockChange(this, '@item.Id')" disabled>
                                    <option value="">-</option>
                                    <option value="true" selected="@(item.CanBlock == true ? "selected" : null)">Sí</option>
                                    <option value="false" selected="@(item.CanBlock == false ? "selected" : null)">No</option>
                                </select>
                            </span></div>
                            <div class="ifield" id="field-blockamount-@item.Id" style="display:@(item.CanBlock == true ? "" : "none")"><span class="ilabel">Block Amount</span><span class="ivalue"><input class="form-control form-control-sm" type="number" step="0.01" name="EditItem.BlockAmount" value="@item.BlockAmount?.ToString("0.##")" disabled /></span></div>
                            <div class="ifield" id="field-blocksound-@item.Id" style="display:@(item.CanBlock == true ? "" : "none")"><span class="ilabel">Block Sound</span><span class="ivalue" style="display:flex;flex-direction:column;gap:0.25rem">
                                @if (item.BlockSoundsNavigation != null)
                                {
                                    <span style="font-size:0.75rem;color:var(--text-muted)">🔊 @(item.BlockSoundsNavigation.Name ?? $"#{item.BlockSoundsNavigation.Id}")</span>
                                }
                                <input class="form-control form-control-sm" type="file" name="EditBlockSound" accept="audio/*" disabled />
                            </span></div>
                            <div class="ifield" id="field-parryaudio-@item.Id" style="display:@(item.CanBlock == true ? "" : "none")"><span class="ilabel">Parry Audio</span><span class="ivalue" style="display:flex;flex-direction:column;gap:0.25rem">
                                @if (item.ParryAudioNavigation != null)
                                {
                                    <span style="font-size:0.75rem;color:var(--text-muted)">🔊 @(item.ParryAudioNavigation.Name ?? $"#{item.ParryAudioNavigation.Id}")</span>
                                }
                                <input class="form-control form-control-sm" type="file" name="EditParryAudio" accept="audio/*" disabled />
                            </span></div>
                        </div>
                    </div>

                    <div class="icard" id="card-magic-@item.Id" style="display:@(item.ItemType?.ToLower() == "book" ? "" : "none")">
                        <div class="icard-header">✨ Magic Data</div>
                        <div class="icard-body">
                            <div id="magic-list-@item.Id">
                            @foreach (var ma in Model.MagicAttacksByItem[item.Id])
                            {
                                <div class="magic-attack-row" data-magic-id="@ma.Id">
                                    <span class="badge bg-secondary">@(ma.MagicTypeNavigation?.Id ?? ma.MagicType)</span>
                                    <span>DMG: @(ma.MagicDamage?.ToString() ?? "-")</span>
                                    <span>CD: @(ma.Cooldown?.ToString("0.##") ?? "-")</span>
                                    <span>Mana: @(ma.ManaConsumption?.ToString() ?? "-")</span>
                                    <button type="button" class="btn btn-outline-info btn-sm edit-only" onclick="openEditMagic('@item.Id', @ma.Id, '@ma.MagicType', @(ma.MagicDamage?.ToString() ?? "null"), @(ma.Cooldown?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null"), @(ma.ProjectileSpeed?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null"), '@(ma.EffectType ?? "")', @(ma.ManaConsumption?.ToString() ?? "null"), @(ma.MaxCompanions?.ToString() ?? "null"))">✏️</button>
                                    <button type="button" class="btn btn-outline-danger btn-sm edit-only" onclick="deleteMagic('@item.Id', @ma.Id, this.closest('.magic-attack-row'))">🗑️</button>
                                </div>
                            }
                            </div>
                            <div class="ifield edit-only" style="padding-top:0.5rem;border-top:1px solid var(--border-subtle)">
                                <span class="ilabel" style="color:var(--text-muted)">+ Attack</span>
                                <span class="ivalue"><button type="button" class="btn btn-outline-success btn-sm" onclick="openAddMagic('@item.Id')">+</button></span>
                            </div>
                        </div>
                    </div>

                </div>
                </form>

            </div>
        }
    </div>
    <!-- Sub-forms fuera de cualquier form para evitar anidamiento -->
    <form id="addItemTypeForm" method="post" asp-page-handler="AddItemType" class="inline-add-form" style="display:none;position:absolute">
        <input class="form-control form-control-sm" name="NewItemTypeValue" placeholder="Nuevo tipo..." required />
        <button type="submit" class="btn btn-sm btn-success">✓</button>
        <button type="button" class="btn btn-sm btn-secondary" onclick="toggleInline('addItemTypeForm')">✕</button>
    </form>
    <form id="addRarityForm" method="post" asp-page-handler="AddRarity" class="inline-add-form" style="display:none;position:absolute">
        <input class="form-control form-control-sm" name="NewRarityValue" placeholder="Nueva rareza..." required />
        <button type="submit" class="btn btn-sm btn-success">✓</button>
        <button type="button" class="btn btn-sm btn-secondary" onclick="toggleInline('addRarityForm')">✕</button>
    </form>
    <form id="addHoldTypeForm" method="post" asp-page-handler="AddHoldType" class="inline-add-form" style="display:none;position:absolute">
        <input class="form-control form-control-sm" name="NewHoldTypeValue" placeholder="Nuevo hold type..." required />
        <button type="submit" class="btn btn-sm btn-success">✓</button>
        <button type="button" class="btn btn-sm btn-secondary" onclick="toggleInline('addHoldTypeForm')">✕</button>
    </form>
    <form id="addEventTypeForm" method="post" asp-page-handler="AddEventType" enctype="multipart/form-data" class="inline-add-form" style="display:none;position:absolute">
        <input class="form-control form-control-sm" name="NewEventTypeValue" placeholder="Nuevo event type..." required />
        <input type="file" class="form-control form-control-sm" name="NewEventTypeIcon" accept="image/*" />
        <button type="submit" class="btn btn-sm btn-success">✓</button>
        <button type="button" class="btn btn-sm btn-secondary" onclick="toggleInline('addEventTypeForm')">✕</button>
    </form>

    <datalist id="ammoItemList">
        @foreach (var i in Model.Items)
        {
            <option value="@i.Id">@(i.Name != null ? $"{i.Id} — {i.Name}" : i.Id)</option>
        }
    </datalist>
</div>

<script>
    const EQUIP_SLOT_TYPES = ['sword','bow','book','armor','shield','weapon','accesory'];
    const HOLD_TYPES = ['sword','bow','book','shield'];

    // ── Pending state per item ──────────────────────────────────────────────
    const pending = {};
    function getState(itemId) {
        if (!pending[itemId]) pending[itemId] = { stats: [], deletedStats: [], events: [], deletedEvents: [], weapon: null, magic: [], deletedMagic: [] };
        return pending[itemId];
    }

    // ── Stats ───────────────────────────────────────────────────────────────
    let _addStatItemId = null;
    function openAddStat(itemId) {
        _addStatItemId = itemId;
        document.getElementById('pendingStatSelect').value = '';
        document.getElementById('pendingStatAmount').value = '';
        document.getElementById('addStatModal').style.display = 'flex';
    }
    function confirmAddStat() {
        const stat = document.getElementById('pendingStatSelect').value;
        const amount = parseInt(document.getElementById('pendingStatAmount').value);
        if (!stat) return;
        const s = getState(_addStatItemId);
        const entry = { _tempId: Date.now(), stat, amount: isNaN(amount) ? null : amount };
        s.stats.push(entry);
        syncHidden(_addStatItemId);
        // render
        const row = document.createElement('div');
        row.className = 'ifield'; row.dataset.tempId = entry._tempId;
        row.innerHTML = `<span class="ilabel">${stat}</span><span class="ivalue d-flex align-items-center gap-2">${amount ?? '-'}<button type="button" class="btn btn-outline-danger btn-sm py-0 px-1" onclick="deletePendingStat('${_addStatItemId}', ${entry._tempId}, this.closest('.ifield'))">✕</button></span>`;
        document.getElementById('stats-list-' + _addStatItemId).appendChild(row);
        document.getElementById('addStatModal').style.display = 'none';
    }
    function deleteStat(itemId, id, el) {
        getState(itemId).deletedStats.push(id);
        syncHidden(itemId);
        el.remove();
    }
    function deletePendingStat(itemId, tempId, el) {
        const s = getState(itemId);
        s.stats = s.stats.filter(x => x._tempId !== tempId);
        syncHidden(itemId);
        el.remove();
    }

    // ── Events ──────────────────────────────────────────────────────────────
    let _addEventItemId = null;
    function openAddEvent(itemId) {
        _addEventItemId = itemId;
        document.getElementById('pendingEventTypeSelect').value = '';
        document.getElementById('addItemEventModal').style.display = 'flex';
    }
    function confirmAddEvent() {
        const sel = document.getElementById('pendingEventTypeSelect');
        const eventTypeId = sel.value;
        if (!eventTypeId) return;
        const opt = sel.options[sel.selectedIndex];
        const icon = opt.dataset.icon;
        const s = getState(_addEventItemId);
        const entry = { _tempId: Date.now(), eventTypeId };
        s.events.push(entry);
        syncHidden(_addEventItemId);
        const row = document.createElement('div');
        row.className = 'ifield'; row.dataset.tempId = entry._tempId;
        row.innerHTML = `<span class="ilabel">Event</span><span class="ivalue d-flex align-items-center gap-2">${icon ? `<img src="data:image/png;base64,${icon}" style="width:20px;height:20px;object-fit:contain;image-rendering:pixelated"/>` : ''}<span class="badge bg-secondary">${eventTypeId}</span><button type="button" class="btn btn-outline-danger btn-sm py-0 px-1" onclick="deletePendingEvent('${_addEventItemId}', ${entry._tempId}, this.closest('.ifield'))">✕</button></span>`;
        document.getElementById('events-list-' + _addEventItemId).appendChild(row);
        document.getElementById('addItemEventModal').style.display = 'none';
    }
    function deleteEvent(itemId, id, el) {
        getState(itemId).deletedEvents.push(id);
        syncHidden(itemId);
        el.remove();
    }
    function deletePendingEvent(itemId, tempId, el) {
        const s = getState(itemId);
        s.events = s.events.filter(x => x._tempId !== tempId);
        syncHidden(itemId);
        el.remove();
    }

    // ── Weapon ──────────────────────────────────────────────────────────────
    function syncWeapon(itemId) {
        const damage = parseInt(document.getElementById('wInline-damage-' + itemId).value) || null;
        const heaviness = parseInt(document.getElementById('wInline-heaviness-' + itemId).value) || null;
        const cooldown = parseFloat(document.getElementById('wInline-cooldown-' + itemId).value) || null;
        const ammo = document.getElementById('wInline-ammo-' + itemId).value || null;
        getState(itemId).weapon = (damage || heaviness || cooldown || ammo) ? { damage, heaviness, ammo, cooldown } : null;
        syncHidden(itemId);
    }

    // ── Magic ───────────────────────────────────────────────────────────────
    let _magicItemId = null;
    function openAddMagic(itemId) {
        _magicItemId = itemId;
        document.getElementById('magicModalEditId').value = '0';
        ['mMagicType','mDamage','mCooldown','mProjSpeed','mEffectType','mMana','mCompanions'].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
        document.getElementById('addMagicModal').style.display = 'flex';
    }
    function openEditMagic(itemId, id, magicType, damage, cooldown, projSpeed, effectType, mana, companions) {
        _magicItemId = itemId;
        document.getElementById('magicModalEditId').value = id;
        document.getElementById('mMagicType').value = magicType ?? '';
        document.getElementById('mDamage').value = damage ?? '';
        document.getElementById('mCooldown').value = cooldown ?? '';
        document.getElementById('mProjSpeed').value = projSpeed ?? '';
        document.getElementById('mEffectType').value = effectType ?? '';
        document.getElementById('mMana').value = mana ?? '';
        document.getElementById('mCompanions').value = companions ?? '';
        document.getElementById('addMagicModal').style.display = 'flex';
    }
    function confirmMagic() {
        const editId = parseInt(document.getElementById('magicModalEditId').value) || 0;
        const entry = {
            id: editId,
            _tempId: editId || Date.now(),
            magicType: document.getElementById('mMagicType').value,
            magicDamage: parseInt(document.getElementById('mDamage').value) || null,
            cooldown: parseFloat(document.getElementById('mCooldown').value) || null,
            projectileSpeed: parseFloat(document.getElementById('mProjSpeed').value) || null,
            effectType: document.getElementById('mEffectType').value || null,
            manaConsumption: parseInt(document.getElementById('mMana').value) || null,
            maxCompanions: parseInt(document.getElementById('mCompanions').value) || null,
        };
        const s = getState(_magicItemId);
        if (editId > 0) {
            // update existing in list
            s.magic = s.magic.filter(x => x.id !== editId);
            const row = document.querySelector(`#magic-list-${_magicItemId} [data-magic-id="${editId}"]`);
            if (row) row.querySelector('.badge').textContent = entry.magicType;
        } else {
            // new row
            const row = document.createElement('div');
            row.className = 'magic-attack-row'; row.dataset.tempId = entry._tempId;
            row.innerHTML = `<span class="badge bg-secondary">${entry.magicType}</span><span>DMG: ${entry.magicDamage ?? '-'}</span><span>CD: ${entry.cooldown ?? '-'}</span><span>Mana: ${entry.manaConsumption ?? '-'}</span><button type="button" class="btn btn-outline-danger btn-sm" onclick="deletePendingMagic('${_magicItemId}', ${entry._tempId}, this.closest('.magic-attack-row'))">🗑️</button>`;
            document.getElementById('magic-list-' + _magicItemId).appendChild(row);
        }
        s.magic.push(entry);
        syncHidden(_magicItemId);
        document.getElementById('addMagicModal').style.display = 'none';
    }
    function deleteMagic(itemId, id, el) {
        getState(itemId).deletedMagic.push(id);
        syncHidden(itemId);
        el.remove();
    }
    function deletePendingMagic(itemId, tempId, el) {
        const s = getState(itemId);
        s.magic = s.magic.filter(x => x._tempId !== tempId);
        syncHidden(itemId);
        el.remove();
    }

    // ── Sync hidden inputs ──────────────────────────────────────────────────
    function syncHidden(itemId) {
        const s = getState(itemId);
        document.getElementById('pendingStats-' + itemId).value = JSON.stringify(s.stats.map(({stat, amount}) => ({stat, amount})));
        document.getElementById('deletedStats-' + itemId).value = JSON.stringify(s.deletedStats);
        document.getElementById('pendingEvents-' + itemId).value = JSON.stringify(s.events.map(({eventTypeId}) => ({eventTypeId})));
        document.getElementById('deletedEvents-' + itemId).value = JSON.stringify(s.deletedEvents);
        document.getElementById('pendingWeapon-' + itemId).value = s.weapon ? JSON.stringify(s.weapon) : '';
        document.getElementById('pendingMagic-' + itemId).value = JSON.stringify(s.magic.map(({id, magicType, magicDamage, cooldown, projectileSpeed, effectType, manaConsumption, maxCompanions}) => ({id: id||0, magicType, magicDamage, cooldown, projectileSpeed, effectType, manaConsumption, maxCompanions})));
        document.getElementById('deletedMagic-' + itemId).value = JSON.stringify(s.deletedMagic);
    }

    // ── Filters ─────────────────────────────────────────────────────────────
    function applyFilters() {
        const q = document.getElementById('itemSearch').value.toLowerCase();
        const type = document.getElementById('f-type').value;
        const rarity = document.getElementById('f-rarity').value;
        const slot = document.getElementById('f-slot').value;
        const hold = document.getElementById('f-hold').value;
        const stack = document.getElementById('f-stack').value;
        const block = document.getElementById('f-block').value;
        const weapon = document.getElementById('f-weapon').value;
        document.querySelectorAll('#itemsList .item-entry').forEach(c => {
            const d = c.dataset;
            const match =
                (!q || d.id.includes(q) || d.name.includes(q) || d.desc.includes(q)) &&
                (!type   || d.type   === type)   &&
                (!rarity || d.rarity === rarity) &&
                (!slot   || d.slot   === slot)   &&
                (!hold   || d.hold   === hold)   &&
                (!stack  || d.stack  === stack)  &&
                (!block  || d.block  === block)  &&
                (!weapon || d.weapon === weapon);
            c.style.display = match ? '' : 'none';
        });
    }
    function toggleFilters() { const p = document.getElementById('filterPanel'); p.style.display = p.style.display === 'none' ? '' : 'none'; }
    function clearFilters() {
        document.getElementById('itemSearch').value = '';
        ['f-type','f-rarity','f-slot','f-hold','f-stack','f-block','f-weapon'].forEach(id => document.getElementById(id).value = '');
        applyFilters();
    }

    // ── Visibility ──────────────────────────────────────────────────────────
    function onNewItemTypeChange(select) {
        const val = select.value.toLowerCase();
        document.getElementById('new-field-equipslot').style.display = EQUIP_SLOT_TYPES.includes(val) ? '' : 'none';
        document.getElementById('new-field-holdtype').style.display = HOLD_TYPES.includes(val) ? '' : 'none';
    }
    function onNewCanBlockChange(select) {
        const show = select.value === 'true';
        ['new-field-blockamount','new-field-blocksound','new-field-parryaudio'].forEach(id => document.getElementById(id).style.display = show ? '' : 'none');
    }
    function onItemTypeChange(select, itemId) {
        const val = select.value.toLowerCase();
        document.getElementById('field-equipslot-' + itemId).style.display = EQUIP_SLOT_TYPES.includes(val) ? '' : 'none';
        document.getElementById('field-holdtype-' + itemId).style.display = HOLD_TYPES.includes(val) ? '' : 'none';
        document.getElementById('card-weapon-' + itemId).style.display = WEAPON_TYPES.includes(val) ? '' : 'none';
        document.getElementById('card-block-' + itemId).style.display = BLOCK_TYPES.includes(val) ? '' : 'none';
        document.getElementById('card-magic-' + itemId).style.display = val === 'book' ? '' : 'none';
    }
    function onCanBlockChange(select, itemId) {
        const show = select.value === 'true';
        ['field-blockamount-','field-blocksound-','field-parryaudio-'].forEach(p => document.getElementById(p + itemId).style.display = show ? '' : 'none');
    }
    const WEAPON_TYPES = ['sword','bow','weapon'];
    const BLOCK_TYPES = ['sword','shield'];
    function applyVisibility(itemId) {
        const form = document.getElementById('form-' + itemId);
        const itemType = form.querySelector('[name="EditItem.ItemType"]').value.toLowerCase();
        const canBlock = form.querySelector('[name="EditItem.CanBlock"]').value;
        document.getElementById('field-equipslot-' + itemId).style.display = EQUIP_SLOT_TYPES.includes(itemType) ? '' : 'none';
        document.getElementById('field-holdtype-' + itemId).style.display = HOLD_TYPES.includes(itemType) ? '' : 'none';
        document.getElementById('card-weapon-' + itemId).style.display = WEAPON_TYPES.includes(itemType) ? '' : 'none';
        document.getElementById('card-block-' + itemId).style.display = BLOCK_TYPES.includes(itemType) ? '' : 'none';
        document.getElementById('card-magic-' + itemId).style.display = itemType === 'book' ? '' : 'none';
        ['field-blockamount-','field-blocksound-','field-parryaudio-'].forEach(p => document.getElementById(p + itemId).style.display = canBlock === 'true' ? '' : 'none');
    }

    // ── Edit mode ───────────────────────────────────────────────────────────
    function enableEdit(itemId) {
        const entry = document.querySelector(`.item-entry[data-id="${itemId.toLowerCase()}"]`);
        const form = document.getElementById('form-' + itemId);
        form.querySelectorAll('input:not([type=hidden]), select').forEach(el => el.disabled = false);
        entry.classList.add('editing');
        applyVisibility(itemId);
        document.querySelector(`[onclick="enableEdit('${itemId}')"]`).style.display = 'none';
        document.getElementById('btn-save-' + itemId).style.display = '';
        document.getElementById('btn-cancel-' + itemId).style.display = '';
        document.getElementById('icon-btn-' + itemId).style.display = '';
    }
    function cancelEdit(itemId) {
        const entry = document.querySelector(`.item-entry[data-id="${itemId.toLowerCase()}"]`);
        const form = document.getElementById('form-' + itemId);
        form.reset();
        form.querySelectorAll('input:not([type=hidden]), select').forEach(el => el.disabled = true);
        entry.classList.remove('editing');
        delete pending[itemId];
        applyVisibility(itemId);
        document.querySelector(`[onclick="enableEdit('${itemId}')"]`).style.display = '';
        document.getElementById('btn-save-' + itemId).style.display = 'none';
        document.getElementById('btn-cancel-' + itemId).style.display = 'none';
        document.getElementById('icon-btn-' + itemId).style.display = 'none';
        document.getElementById('icon-input-' + itemId).value = '';
        location.reload();
    }
    function onInlineStackableChange(select, itemId) {
        const maxAmount = document.getElementById('inlineMaxAmount-' + itemId);
        if (select.value === 'false') { maxAmount.value = 1; maxAmount.readOnly = true; maxAmount.style.backgroundColor = '#2a2d3e'; }
        else { maxAmount.readOnly = false; maxAmount.style.backgroundColor = ''; }
    }
    function onStackableChange(select) {
        const maxAmount = document.getElementById('maxAmount');
        if (select.value === 'false') { maxAmount.value = 1; maxAmount.readOnly = true; maxAmount.style.backgroundColor = '#2a2d3e'; }
        else { maxAmount.readOnly = false; maxAmount.style.backgroundColor = ''; }
    }

    // ── Inline forms (lookup adds) ──────────────────────────────────────────
    function toggleInline(id, anchorEl) {
        const form = document.getElementById(id);
        const isHidden = form.style.display === 'none' || form.style.display === '';
        form.style.display = isHidden ? 'flex' : 'none';
        if (isHidden && anchorEl) {
            const rect = anchorEl.closest('.input-group, .mb-3').getBoundingClientRect();
            form.style.top = (rect.bottom + window.scrollY + 4) + 'px';
            form.style.left = rect.left + 'px';
            form.style.zIndex = '2000';
            form.querySelector('input').focus();
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[id^="form-"]').forEach(form => {
            const itemId = form.id.replace('form-', '');
            applyVisibility(itemId);
        });
        const filteredItemId = '@Model.FilteredItemId';
        document.querySelectorAll('form').forEach(form => {
            if (!form.querySelector('[name="FilteredItemId"]')) {
                const input = document.createElement('input');
                input.type = 'hidden'; input.name = 'FilteredItemId'; input.value = filteredItemId;
                form.appendChild(input);
            }
        });
    });
</script>
